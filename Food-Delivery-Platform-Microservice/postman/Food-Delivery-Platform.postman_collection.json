    {
      "name": "03 - Full Order Flow [E2E]",
      "description": "Runs the complete customer journey end-to-end:\n1. Customer places an order\n2. Delivery record is automatically created by Delivery Service via RabbitMQ event (no manual trigger)\n3. Delivery progresses through ASSIGNED → PICKED_UP → DELIVERED\n\n**IMPORTANT:** Use Collection Runner with at least 1000 ms delay between requests. The step '[EVENT] Get Delivery by Order' relies on Delivery Service consuming the OrderPlacedEvent — allow time for that to happen.",
      "item": [

        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.collectionVariables.set('orderId', String(b.id));",
                  "pm.test('Order ID set', () => pm.expect(b.id).to.be.a('number'));",
                  "pm.test('Status is PLACED', () => pm.expect(b.status).to.equal('PLACED'));",
                  "pm.test('Total amount calculated', () => pm.expect(b.totalAmount).to.be.above(0));",
                  "pm.test('Delivery fee applied', () => pm.expect(b.deliveryFee).to.be.above(0));",
                  "pm.test('Customer ID matches', () => pm.expect(String(b.customerId)).to.equal(pm.collectionVariables.get('customerId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"restaurantId\": {{restaurantId}},\n  \"items\": [\n    {\n      \"menuItemId\": {{menuItemId}},\n      \"quantity\": 2,\n      \"specialInstructions\": \"No spice\"\n    }\n  ],\n  \"deliveryAddress\": \"123 Test Street, Kigali\",\n  \"specialInstructions\": \"Ring the bell\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          },
          "response": []
        },

        {
          "name": "Verify Order Placed",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Correct order ID', () => pm.expect(String(b.id)).to.equal(pm.collectionVariables.get('orderId')));",
                  "pm.test('Status is PLACED', () => pm.expect(b.status).to.equal('PLACED'));",
                  "pm.test('Has line items', () => pm.expect(b.items.length).to.be.at.least(1));",
                  "pm.test('Item name is set', () => pm.expect(b.items[0].itemName).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          },
          "response": []
        },

        {
          "name": "[EVENT] Get Delivery by Order — auto-assigned via RabbitMQ",
          "description": "This request verifies event-driven delivery assignment.\n\nWhen the order was placed, Order Service published an OrderPlacedEvent to order.exchange. Delivery Service consumed it from order.placed.queue and created a Delivery record automatically — no REST call triggered the creation.\n\nIf this returns 404, the event has not been processed yet. Wait a moment and retry, or increase the Collection Runner delay.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 — delivery auto-created by event', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.collectionVariables.set('deliveryId', String(b.id));",
                  "pm.test('Delivery ID set', () => pm.expect(b.id).to.be.a('number'));",
                  "pm.test('Linked to correct order', () => pm.expect(String(b.orderId)).to.equal(pm.collectionVariables.get('orderId')));",
                  "pm.test('Initial status is PENDING', () => pm.expect(b.status).to.equal('PENDING'));",
                  "pm.test('Customer username recorded', () => pm.expect(b.customerUsername).to.equal(pm.collectionVariables.get('customerUsername')));",
                  "pm.test('Pickup address from restaurant', () => pm.expect(b.pickupAddress).to.be.a('string').and.not.empty);",
                  "pm.test('Delivery address from order', () => pm.expect(b.deliveryAddress).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/order/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "order", "{{orderId}}"]
            }
          },
          "response": []
        },

        {
          "name": "Update Delivery Status → ASSIGNED",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ASSIGNED', () => pm.expect(pm.response.json().status).to.equal('ASSIGNED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/{{deliveryId}}/status?status=ASSIGNED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "{{deliveryId}}", "status"],
              "query": [{ "key": "status", "value": "ASSIGNED" }]
            }
          },
          "response": []
        },

        {
          "name": "Update Delivery Status → PICKED_UP",
          "description": "Transitioning to PICKED_UP publishes a DeliveryStatusUpdatedEvent to delivery.exchange. Check the RabbitMQ management UI (localhost:15672) to observe the message on delivery.status.queue.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
