{
  "info": {
    "name": "Food Delivery Platform — E2E",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end tests for the Food Delivery Platform microservices.\n\n**Prerequisites:** All services running (Docker: `docker compose up --build`).\n\n**Collection Runner settings:** Set delay to 1000 ms to allow RabbitMQ event propagation before the delivery check in folder 03.\n\n**Run order:** Folders must run in sequence 01 → 02 → 03 → 04. Folder 05 requires manual service disruption — read each request description first."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" }
  ],
  "item": [

    {
      "name": "01 - Setup",
      "description": "Register two accounts and authenticate both. A timestamp suffix is appended to usernames so the collection can be re-run without conflicts.",
      "item": [

        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString().slice(-6);",
                  "pm.environment.set('usernamesSuffix', suffix);",
                  "pm.environment.set('customerUsername', 'e2e_customer_' + suffix);",
                  "pm.environment.set('ownerUsername', 'e2e_owner_' + suffix);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.environment.set('customerToken', b.token);",
                  "pm.environment.set('customerId', String(b.customerId));",
                  "pm.test('JWT token returned', () => pm.expect(b.token).to.be.a('string').and.not.empty);",
                  "pm.test('Default role is CUSTOMER', () => pm.expect(b.role).to.equal('CUSTOMER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"username\": \"e2e_customer_{{usernamesSuffix}}\",\n  \"email\": \"e2e_customer_{{usernamesSuffix}}@test.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Customer\",\n  \"phone\": \"+250780000001\",\n  \"deliveryAddress\": \"123 Test Street\",\n  \"city\": \"Kigali\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },

