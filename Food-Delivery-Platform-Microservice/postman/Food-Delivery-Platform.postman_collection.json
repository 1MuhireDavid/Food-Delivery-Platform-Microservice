{
  "info": {
    "name": "Food Delivery Platform — E2E",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end tests for the Food Delivery Platform microservices.\n\n**Prerequisites:** All services must be running (Docker: `docker compose up --build` or local startup order in README).\n\n**Collection Runner settings:** Set delay between requests to 1000 ms — this gives RabbitMQ time to propagate the OrderPlacedEvent before '03 - Full Order Flow' checks for the delivery record.\n\n**Run order:** Folders must run in sequence 01 → 02 → 03 → 04. Folder 05 (Fault Tolerance) requires manual steps — read each request description before sending."
  },
  "variable": [
    { "key": "baseUrl",           "value": "http://localhost:8080", "type": "string" },
    { "key": "customerUsername",  "value": "e2e_customer",          "type": "string" },
    { "key": "customerPassword",  "value": "password123",           "type": "string" },
    { "key": "ownerUsername",     "value": "e2e_owner",             "type": "string" },
    { "key": "ownerPassword",     "value": "password123",           "type": "string" },
    { "key": "customerToken",     "value": "",                      "type": "string" },
    { "key": "ownerToken",        "value": "",                      "type": "string" },
    { "key": "customerId",        "value": "",                      "type": "string" },
    { "key": "restaurantId",      "value": "",                      "type": "string" },
    { "key": "menuItemId",        "value": "",                      "type": "string" },
    { "key": "orderId",           "value": "",                      "type": "string" },
    { "key": "cancelOrderId",     "value": "",                      "type": "string" },
    { "key": "deliveryId",        "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "01 - Setup",
      "description": "Register two accounts and authenticate both. A timestamp suffix is appended to usernames so the collection can be re-run against the same database without conflicts.",
      "item": [

        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString().slice(-6);",
                  "pm.collectionVariables.set('customerUsername', 'e2e_customer_' + suffix);",
                  "pm.collectionVariables.set('ownerUsername',    'e2e_owner_'    + suffix);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.collectionVariables.set('customerToken', b.token);",
                  "pm.collectionVariables.set('customerId', String(b.customerId));",
                  "pm.test('JWT token returned', () => pm.expect(b.token).to.be.a('string').and.not.empty);",
                  "pm.test('Default role is CUSTOMER', () => pm.expect(b.role).to.equal('CUSTOMER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"username\": \"{{customerUsername}}\",\n  \"email\": \"{{customerUsername}}@test.com\",\n  \"password\": \"{{customerPassword}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Customer\",\n  \"phone\": \"+250780000001\",\n  \"deliveryAddress\": \"123 Test Street\",\n  \"city\": \"Kigali\"\n}"
