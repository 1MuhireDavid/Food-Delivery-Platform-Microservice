    {
      "name": "03 - Full Order Flow [E2E]",
      "description": "Complete customer journey end-to-end.\n\n1. Customer places an order\n2. Order Service publishes OrderPlacedEvent to RabbitMQ\n3. Delivery Service auto-creates a Delivery record by consuming that event\n4. Delivery progresses through ASSIGNED → PICKED_UP → DELIVERED\n\n**IMPORTANT:** Run with 1000 ms delay between requests. The '[EVENT] Get Delivery by Order' step checks for a delivery that Delivery Service must create asynchronously.",
      "item": [

        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.environment.set('orderId', String(b.id));",
                  "pm.test('Order ID set', () => pm.expect(b.id).to.be.a('number'));",
                  "pm.test('Status is PLACED', () => pm.expect(b.status).to.equal('PLACED'));",
                  "pm.test('Total amount calculated', () => pm.expect(b.totalAmount).to.be.above(0));",
                  "pm.test('Delivery fee applied', () => pm.expect(b.deliveryFee).to.be.above(0));",
                  "pm.test('Customer ID matches', () => pm.expect(String(b.customerId)).to.equal(pm.environment.get('customerId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"restaurantId\": {{restaurantId}},\n  \"items\": [\n    {\n      \"menuItemId\": {{menuItemId}},\n      \"quantity\": 2,\n      \"specialInstructions\": \"No spice\"\n    }\n  ],\n  \"deliveryAddress\": \"123 Test Street, Kigali\",\n  \"specialInstructions\": \"Ring the bell\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          },
          "response": []
        },

        {
          "name": "Verify Order Placed",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Correct order ID', () => pm.expect(String(b.id)).to.equal(pm.environment.get('orderId')));",
                  "pm.test('Status is PLACED', () => pm.expect(b.status).to.equal('PLACED'));",
                  "pm.test('Has line items', () => pm.expect(b.items.length).to.be.at.least(1));",
                  "pm.test('Item name is set', () => pm.expect(b.items[0].itemName).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          },
          "response": []
        },

        {
          "name": "[EVENT] Get Delivery by Order — auto-created via RabbitMQ",
          "description": "Verifies event-driven delivery assignment.\n\nWhen the order was placed, Order Service published an OrderPlacedEvent to order.exchange. Delivery Service consumed it from order.placed.queue and created this Delivery record automatically — no REST call triggered it.\n\nIf this returns 404, the event has not been processed yet. Increase the Collection Runner delay to 2000 ms and retry.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 — delivery auto-created by RabbitMQ event', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.environment.set('deliveryId', String(b.id));",
                  "pm.test('Delivery ID set', () => pm.expect(b.id).to.be.a('number'));",
                  "pm.test('Linked to correct order', () => pm.expect(String(b.orderId)).to.equal(pm.environment.get('orderId')));",
                  "pm.test('Initial status is PENDING', () => pm.expect(b.status).to.equal('PENDING'));",
                  "pm.test('Customer username recorded', () => pm.expect(b.customerUsername).to.equal(pm.environment.get('customerUsername')));",
                  "pm.test('Pickup address populated from restaurant', () => pm.expect(b.pickupAddress).to.be.a('string').and.not.empty);",
                  "pm.test('Delivery address populated from order', () => pm.expect(b.deliveryAddress).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/order/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "order", "{{orderId}}"]
            }
          },
          "response": []
        },

        {
          "name": "Update Delivery Status → ASSIGNED",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ASSIGNED', () => pm.expect(pm.response.json().status).to.equal('ASSIGNED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/{{deliveryId}}/status?status=ASSIGNED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "{{deliveryId}}", "status"],
              "query": [{ "key": "status", "value": "ASSIGNED" }]
            }
          },
          "response": []
        },

        {
          "name": "Update Delivery Status → PICKED_UP",
          "description": "Transitioning to PICKED_UP publishes a DeliveryStatusUpdatedEvent to delivery.exchange. Check the RabbitMQ management UI (localhost:15672) to observe the message on delivery.status.queue.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Status is PICKED_UP', () => pm.expect(b.status).to.equal('PICKED_UP'));",
                  "pm.test('pickedUpAt timestamp set', () => pm.expect(b.pickedUpAt).to.not.be.null);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/{{deliveryId}}/status?status=PICKED_UP",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "{{deliveryId}}", "status"],
              "query": [{ "key": "status", "value": "PICKED_UP" }]
            }
          },
          "response": []
        },

        {
          "name": "Update Delivery Status → DELIVERED",
          "description": "Final step. Also publishes a DeliveryStatusUpdatedEvent to delivery.exchange.",
          "event": [
            {
              "listen": "test",
              "script": {
